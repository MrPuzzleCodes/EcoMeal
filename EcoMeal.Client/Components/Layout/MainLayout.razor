@inherits LayoutComponentBase
@using EcoMeal.Client.Services
@using Microsoft.AspNetCore.Components.Authorization
@inject AuthService AuthService
@inject NavigationManager Navigation

<div class="page" style="background-color: #f5fff6">
    <header>
        <nav class="navbar navbar-expand-lg navbar-light bg-success text-light sticky-top px-4">
            <a class="navbar-brand font-weight-bold text-light" href="/">EcoMeal</a>
            <div class="ms-auto">
                @if (AuthService.IsAuthenticated)
                {
                    <AuthorizeView Roles="Admin">
                        <a class="btn btn-outside-light border-light text-light btn-sm me-2" href="/orders/all">Admin Order Panel</a>
                    </AuthorizeView>
                    <AuthorizeView Roles="User">
                        <a class="btn btn-outside-light border-light text-light btn-sm me-2" href="/orders/my">Orders</a>
                    </AuthorizeView>
                    <a class="btn border-info text-info btn-sm me-2">Logged In</a>
                    <button class="btn btn-danger btn-sm" @onclick="HandleLogout">Logout</button>
                }
                else
                {
                    <a class="btn btn-primary btn-sm" href="/login">Login</a>
                }
            </div>
        </nav>
    </header>
    <main>
        <article class="content px-4 py-3">
            @Body
        </article>
    </main>
</div>

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await AuthService.LoadTokenAsync();
            StateHasChanged();
        }
    }

    private async Task HandleLogout()
    {
        await AuthService.LogoutAsync();
        Navigation.NavigateTo("/", forceLoad: true);
    }
}
