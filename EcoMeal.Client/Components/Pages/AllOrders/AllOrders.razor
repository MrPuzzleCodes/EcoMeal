@page "/orders/all"
@namespace EcoMeal.Client.Components.Pages.AllOrders

<PageTitle>All Orders</PageTitle>
<div class="container">
    <h1>All Orders</h1>

    @if(AllOrdersList is null){
        <p>Loading...</p>
    }else if(!AllOrdersList.Any()){
        <div class="alert">
            No Orders Exist.
        </div>
    }else{

        <div class="row g-3">
            @foreach(var order in AllOrdersList){
                <div class="col-12">
                    <div class="card">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start">
                                <h3 class = "card-title mb-1">@order.PackageName</h3>
                                <p class="text-muted small">@order.BusinessName</p>
                                <p class="text-muted small">@order.Date.ToString("dd.MM.yyyy HH:mm")</p>
                            </div>
                            <div class="text-end">
                                <span class="badge rounded=pill bg-success-subtle text-success-emphasis">@order.Status</span>
                                <div class="fw-semibold">@order.Price RON</div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>